{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "express": [
        "apps/connectshyft-api/node_modules/express",
        "apps/moneyshyft-api/node_modules/express"
      ],
      "joi": [
        "apps/connectshyft-api/node_modules/joi",
        "apps/moneyshyft-api/node_modules/joi"
      ],
      "jsonwebtoken": [
        "apps/connectshyft-api/node_modules/jsonwebtoken",
        "apps/moneyshyft-api/node_modules/jsonwebtoken"
      ],
      "knex": [
        "apps/connectshyft-api/node_modules/knex",
        "apps/moneyshyft-api/node_modules/knex"
      ],
      "pinia": ["apps/moneyshyft-web/node_modules/pinia"],
      "vue": ["apps/moneyshyft-web/node_modules/vue"],
      "@shyft/auth": ["libs/auth/src/index.ts"],
      "@shyft/db": ["libs/db/src/index.ts"],
      "@shyft/http": ["libs/http/src/index.ts"],
      "@shyft/platform": ["libs/platform/src/index.ts"],
      "@shyft/ui-shell": ["libs/ui-shell/src/index.ts"],
      "@shyft/contracts": ["libs/contracts/src/index.ts"]
    },
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  }
}
