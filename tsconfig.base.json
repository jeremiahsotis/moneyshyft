{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "express": ["apps/moneyshyft-api/node_modules/express"],
      "joi": ["apps/moneyshyft-api/node_modules/joi"],
      "jsonwebtoken": ["apps/moneyshyft-api/node_modules/jsonwebtoken"],
      "knex": ["apps/moneyshyft-api/node_modules/knex"],
      "pinia": ["apps/moneyshyft-web/node_modules/pinia"],
      "vue": ["apps/moneyshyft-web/node_modules/vue"],
      "@shyft/auth": ["libs/auth/src/index.ts"],
      "@shyft/db": ["libs/db/src/index.ts"],
      "@shyft/http": ["libs/http/src/index.ts"],
      "@shyft/platform": ["libs/platform/src/index.ts"],
      "@shyft/ui-shell": ["libs/ui-shell/src/index.ts"]
    },
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  }
}
