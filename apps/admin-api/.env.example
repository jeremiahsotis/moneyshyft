# Server Configuration
NODE_ENV=development
PORT=3100

# Database
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=moneyshyft
DB_USER=jeremiahotis
DB_PASSWORD=change-me
# Optional single-variable form:
# DATABASE_URL=postgresql://jeremiahotis:change-me@127.0.0.1:5432/moneyshyft

# JWT Secrets (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=your_jwt_secret_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_change_in_production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

CONNECTSHYFT_ENABLED=true
CONNECTSHYFT_INBOX_ENABLED=true
CONNECTSHYFT_ESCALATION_ENABLED=true
CONNECTSHYFT_WEBHOOKS_ENABLED=true
ADMIN_CONSOLE_V1=true
INTEGRITY_DASHBOARD_V1=true

# MoneyShyft WP cutover stage (bridge | monolith_authoritative | read_only)
# Set explicitly in each environment. Recommended production baseline: monolith_authoritative
MONEYSHYFT_WP_CUTOVER_STAGE=bridge

# Frontend URL (for CORS)
FRONTEND_URL=http://127.0.0.1:5174

# Password reset link target (admin-web or module login reset page)
PASSWORD_RESET_BASE_URL=http://127.0.0.1:5174/auth/password/reset
PASSWORD_RESET_TOKEN_TTL_MINUTES=60

# API Configuration
API_BASE_URL=http://localhost:3000/api/v1

# Logging
LOG_LEVEL=debug
