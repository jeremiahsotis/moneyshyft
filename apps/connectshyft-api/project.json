{
  "name": "connectshyft-api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/connectshyft-api/src",
  "tags": ["lane:connectshyft", "type:app", "runtime:node"],
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/connectshyft-api",
        "command": "npm run dev"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "inputs": ["default", "{workspaceRoot}/domains/communication/**/*"],
      "options": {
        "cwd": "apps/connectshyft-api",
        "command": "npm run build"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/connectshyft-api",
        "command": "npm run start"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "inputs": ["default", "{workspaceRoot}/domains/communication/**/*"],
      "options": {
        "cwd": "apps/connectshyft-api",
        "command": "npm run test:integration"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node scripts/enforce-workspace-boundaries.js"
      }
    }
  }
}
