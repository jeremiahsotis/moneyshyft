NODE_ENV=production
PORT=3100

DATABASE_URL=postgresql://moneyshyft_app:REPLACE_DB_PASSWORD@host.docker.internal:5432/moneyshyft

FRONTEND_URL=https://admin.shyftunity.com
PASSWORD_RESET_BASE_URL=https://admin.shyftunity.com/auth/password/reset
COOKIE_DOMAIN=shyftunity.com

JWT_SECRET=REPLACE_JWT_SECRET
JWT_REFRESH_SECRET=REPLACE_JWT_REFRESH_SECRET
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

CONNECTSHYFT_ENABLED=true
CONNECTSHYFT_INBOX_ENABLED=true
CONNECTSHYFT_ESCALATION_ENABLED=true
CONNECTSHYFT_WEBHOOKS_ENABLED=true
ADMIN_CONSOLE_V1=true
INTEGRITY_DASHBOARD_V1=true

MONEYSHYFT_WP_CUTOVER_STAGE=monolith_authoritative
LOG_LEVEL=info
