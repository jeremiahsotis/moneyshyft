FROM node:20-alpine

WORKDIR /app

COPY package*.json ./
COPY knexfile.js ./
COPY tsconfig.json ./

RUN npm ci && npm cache clean --force

COPY . .

RUN npm run build
RUN npm prune --production && npm cache clean --force

ENV NODE_ENV=production
ENV NODE_OPTIONS="--max-old-space-size=384"

EXPOSE 3100

CMD ["node", "dist/server.js"]
