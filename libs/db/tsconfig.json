{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "types": ["node"],
    "typeRoots": [
      "../../node_modules/@types",
      "../../apps/moneyshyft-api/node_modules/@types",
      "../../apps/admin-api/node_modules/@types"
    ],
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "sourceMap": false,
    "esModuleInterop": true,
    "preserveSymlinks": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
